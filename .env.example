# Database connection (used by the app via adapter)
DATABASE_HOST=db
DATABASE_USER=killbill
DATABASE_PASSWORD=change_me_password
DATABASE_NAME=killbill
DATABASE_PORT=3306

# Prisma CLI uses this for migrations (constructed from above)
DATABASE_URL="mysql://killbill:change_me_password@db:3306/killbill"

# Docker Compose MySQL container (only needed if using docker-compose)
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PASSWORD=change_me_password

# JWT Secret for Session Signing
JWT_SECRET=change_me_secret
