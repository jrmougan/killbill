generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Couple {
  id        String    @id @default(cuid())
  name      String?
  code      String    @unique // For invites
  createdAt DateTime  @default(now())

  members     User[]
  expenses    Expense[]
  settlements Settlement[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  pin       String?
  avatar    String?
  password  String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Couple support (one user, one couple)
  coupleId String?
  couple   Couple? @relation(fields: [coupleId], references: [id])

  expensesPaid Expense[] @relation("Payer")
  splits       Split[]

  settlementsPaid     Settlement[] @relation("SettlementPayer")
  settlementsReceived Settlement[] @relation("SettlementReceiver")
  
  inviteCodesCreated InviteCode[] @relation("InviteCreator")
  inviteCodeUsed     InviteCode?  @relation("InviteUser")
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  expiresAt DateTime?
  
  // Who created this invite
  createdById String
  createdBy   User   @relation("InviteCreator", fields: [createdById], references: [id])
  
  // Who used this invite (null if unused)
  usedById String? @unique
  usedBy   User?   @relation("InviteUser", fields: [usedById], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime @default(now())
  category    String   @default("other")

  receiptUrl  String?
  receiptData Json?

  paidById String
  paidBy   User   @relation("Payer", fields: [paidById], references: [id])

  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id])

  splits Split[]
  
  settlementId String?
  settlement   Settlement? @relation(fields: [settlementId], references: [id])

  @@index([coupleId])
  @@index([paidById])
}

model Split {
  id     String @id @default(cuid())
  amount Float

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
}

model Settlement {
  id   String   @id @default(cuid())
  date DateTime @default(now())

  // Who is settling their debt (The Debtor)
  fromUserId String
  fromUser   User   @relation("SettlementPayer", fields: [fromUserId], references: [id])

  // Who is receiving the settlement (The Creditor)
  toUserId String
  toUser   User   @relation("SettlementReceiver", fields: [toUserId], references: [id])

  coupleId String
  couple   Couple @relation(fields: [coupleId], references: [id])

  amount Float // Total amount of the settlement
  status String @default("PENDING") // PENDING, CONFIRMED, REJECTED
  method String @default("CASH") // CASH, BIZUM, TRANSFER, etc.

  expenses Expense[]

  @@index([coupleId])
  @@index([fromUserId])
  @@index([toUserId])
}
